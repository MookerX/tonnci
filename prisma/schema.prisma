// =============================================================================
// 腾曦生产管理系统 - Prisma数据库Schema
// 描述: 完整的数据库模型定义
// 版本: 1.0.0
// =============================================================================

generator client {
  provider   = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// =============================================================================
// 通用字段模型
// =============================================================================

// 系统初始化状态表
model SystemInitStatus {
  id              Int       @id @default(autoincrement())
  initStep        String    @map("init_step") @db.VarChar(50)
  stepStatus      String    @default("pending") @map("step_status") @db.VarChar(20)
  completedAt     DateTime? @map("completed_at")
  configData      String?   @db.Text @map("config_data")
  isDelete        Boolean   @default(false)
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  @@map("system_init_status")
}

// 系统配置表
model SystemConfig {
  id         Int       @id @default(autoincrement())
  paramKey   String    @unique @db.VarChar(100)
  paramValue String    @db.Text
  paramType  String    @default("string") @db.VarChar(20)
  remark     String?   @db.Text
  isDelete   Boolean   @default(false)
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")
  createdBy  Int?      @map("created_by")
  modifiedBy Int?      @map("modified_by")

  @@map("system_config")
}

// 系统字典表
model SystemDict {
  id         Int       @id @default(autoincrement())
  dictType   String    @db.VarChar(50)
  dictLabel  String    @db.VarChar(100)
  dictValue  String    @db.VarChar(100)
  sortOrder  Int       @default(0) @map("sort_order")
  status     String    @default("active") @db.VarChar(20)
  remark     String?   @db.Text
  isDelete   Boolean   @default(false)
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")
  createdBy  Int?      @map("created_by")
  modifiedBy Int?      @map("modified_by")

  @@index([dictType], name: "idx_dict_type")
  @@map("system_dict")
}

// 编码规则表
model CodeRule {
  id           Int       @id @default(autoincrement())
  ruleName     String    @map("rule_name") @db.VarChar(100)
  ruleCode     String    @unique @map("rule_code") @db.VarChar(50)
  prefix       String?   @db.VarChar(20)
  dateFormat   String    @default("") @map("date_format") @db.VarChar(20)
  seqLength    Int       @default(4) @map("seq_length")
  suffix       String?   @db.VarChar(20)
  resetType    String    @default("daily") @map("reset_type") @db.VarChar(20)
  currentSeq   Int       @default(0) @map("current_seq")
  lastResetDate DateTime? @map("last_reset_date")
  remark       String?   @db.Text
  isDelete     Boolean   @default(false)
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  createdBy    Int?      @map("created_by")

  @@map("code_rule")
}

// 操作日志表
model OperationLog {
  id            Int       @id @default(autoincrement())
  moduleName    String    @map("module_name") @db.VarChar(50)
  businessType  String    @map("business_type") @db.VarChar(50)
  operatorId    Int?      @map("operator_id")
  operatorName  String?   @map("operator_name") @db.VarChar(50)
  operationDesc String?   @map("operation_desc") @db.Text
  requestParams String?   @map("request_params") @db.Text
  ipAddress     String?   @map("ip_address") @db.VarChar(50)
  status        String    @default("success") @db.VarChar(20)
  errorMessage  String?   @map("error_message") @db.Text
  isDelete      Boolean   @default(false)
  createdAt     DateTime  @default(now()) @map("created_at")

  @@index([operatorId], name: "idx_operator")
  @@index([moduleName], name: "idx_module")
  @@index([createdAt], name: "idx_created")
  @@map("operation_log")
}

// 文件记录表
model FileRecord {
  id           Int       @id @default(autoincrement())
  fileName     String    @map("file_name") @db.VarChar(255)
  filePath     String    @map("file_path") @db.Text
  fileSize     BigInt    @default(0) @map("file_size")
  md5          String?   @db.VarChar(64)
  storageType  String    @map("storage_type") @db.VarChar(50)
  fileCategory String?   @map("file_category") @db.VarChar(50)
  materialId   Int?      @map("material_id")
  uploaderId   Int?      @map("uploader_id")
  version      Int       @default(1)
  parentMd5    String?   @map("parent_md5") @db.VarChar(64)
  status       String    @default("active") @db.VarChar(20)
  nasDeviceId  Int?      @map("nas_device_id")
  remark       String?   @db.Text
  isDelete     Boolean   @default(false)
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  createdBy    Int?      @map("created_by")

  @@index([materialId], name: "idx_material")
  @@index([md5], name: "idx_md5")
  @@map("file_record")
}

// NAS设备表
model NasDevice {
  id           Int       @id @default(autoincrement())
  deviceName   String    @map("device_name") @db.VarChar(100)
  deviceType   String    @default("synology") @map("device_type") @db.VarChar(20)
  host         String    @db.VarChar(255)
  port         Int       @default(445)
  username     String    @db.VarChar(100)
  password     String    @db.Text
  sharePath    String    @map("share_path") @db.Text
  storageTypes String    @db.Text
  isDefault    Boolean   @default(false) @map("is_default")
  status       String    @default("active") @db.VarChar(20)
  remark       String?   @db.Text
  isDelete     Boolean   @default(false)
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  createdBy    Int?      @map("created_by")
  modifiedBy   Int?      @map("modified_by")

  @@map("nas_device")
}

// 数据库配置表
model DatabaseConfig {
  id           Int       @id @default(autoincrement())
  moduleName   String    @map("module_name") @db.VarChar(100)
  moduleCode   String    @unique @map("module_code") @db.VarChar(50)
  host         String    @db.VarChar(255)
  port         Int       @default(3306)
  database     String    @db.VarChar(100)
  username     String    @db.VarChar(100)
  password     String    @db.Text
  isEnabled    Boolean   @default(false) @map("is_enabled")
  remark       String?   @db.Text
  isDelete     Boolean   @default(false)
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  createdBy    Int?      @map("created_by")
  modifiedBy   Int?      @map("modified_by")

  @@map("database_config")
}

// =============================================================================
// 用户与权限模块
// =============================================================================

// 用户表
model User {
  id           Int       @id @default(autoincrement())
  uuid         String    @unique @db.VarChar(36)
  username     String    @unique @db.VarChar(50)
  password     String    @db.VarChar(255)
  realName     String?   @map("real_name") @db.VarChar(50)
  phone        String?   @db.VarChar(20)
  email        String?   @db.VarChar(100)
  avatar       String?   @db.VarChar(255)
  deptId       Int?      @map("dept_id")
  userType     String    @default("internal") @map("user_type") @db.VarChar(20)
  customerId   Int?      @map("customer_id")
  roleIds      String?   @map("role_ids") @db.Text
  status       String    @default("active") @db.VarChar(20)
  lastLoginAt  DateTime? @map("last_login_at")
  loginIp      String?   @map("login_ip") @db.VarChar(50)
  remark       String?   @db.Text
  isDelete     Boolean   @default(false)
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  createdBy    Int?      @map("created_by")
  modifiedBy   Int?      @map("modified_by")

  // 关系
  dept         Dept?     @relation("UserDept", fields: [deptId], references: [id])

  @@index([deptId], name: "idx_dept")
  @@index([customerId], name: "idx_customer")
  @@map("user")
}

// 部门表
model Dept {
  id           Int       @id @default(autoincrement())
  parentId     Int?      @map("parent_id")
  deptName     String    @map("dept_name") @db.VarChar(100)
  deptCode     String?   @map("dept_code") @db.VarChar(50)
  leaderName   String?   @map("leader_name") @db.VarChar(50)
  sortOrder    Int       @default(0) @map("sort_order")
  status       String    @default("active") @db.VarChar(20)
  remark       String?   @db.Text
  isDelete     Boolean   @default(false)
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  createdBy    Int?      @map("created_by")
  modifiedBy   Int?      @map("modified_by")

  // 关系
  users        User[]    @relation("UserDept")

  @@map("dept")
}

// 角色表
model Role {
  id           Int       @id @default(autoincrement())
  roleName     String    @map("role_name") @db.VarChar(100)
  roleCode     String    @unique @map("role_code") @db.VarChar(50)
  // 数据权限范围：all=全部数据, dept=本部门数据, deptAndChild=本部门及子部门, custom=自定义
  dataScope    String    @default("custom") @map("data_scope") @db.VarChar(20)
  status       String    @default("active") @db.VarChar(20)
  sortOrder    Int       @default(0) @map("sort_order")
  remark       String?   @db.Text
  isDelete     Boolean   @default(false)
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  createdBy    Int?      @map("created_by")
  modifiedBy   Int?      @map("modified_by")

  @@map("role")
}

// 用户角色关联表
model UserRole {
  id           Int       @id @default(autoincrement())
  userId       Int       @map("user_id")
  roleId       Int       @map("role_id")
  isDelete     Boolean   @default(false)
  createdAt    DateTime  @default(now()) @map("created_at")

  @@unique([userId, roleId], name: "uk_user_role")
  @@map("user_role")
}

// 菜单表
model Menu {
  id           Int       @id @default(autoincrement())
  parentId     Int?      @map("parent_id")
  menuName     String    @map("menu_name") @db.VarChar(100)
  menuCode     String?   @map("menu_code") @db.VarChar(50)
  menuType     String    @default("menu") @map("menu_type") @db.VarChar(20)
  icon         String?   @db.VarChar(50)
  path         String?   @db.VarChar(255)
  component    String?   @db.VarChar(255)
  sortOrder    Int       @default(0) @map("sort_order")
  visible      String    @default("visible") @db.VarChar(20)
  status       String    @default("active") @db.VarChar(20)
  // 权限标识：菜单权限、操作权限（add/edit/delete/view）、接口权限
  permission   String?   @db.VarChar(100)
  remark       String?   @db.Text
  isDelete     Boolean   @default(false)
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  createdBy    Int?      @map("created_by")
  modifiedBy   Int?      @map("modified_by")

  @@map("menu")
}

// 角色权限关联表
model RolePermission {
  id           Int       @id @default(autoincrement())
  roleId       Int       @map("role_id")
  menuId       Int?      @map("menu_id")
  permission   String?   @db.VarChar(100)
  actionType   String?   @map("action_type") @db.VarChar(50)
  isDelete     Boolean   @default(false)
  createdAt    DateTime  @default(now()) @map("created_at")

  @@unique([roleId, menuId, permission], name: "uk_role_menu_perm")
  @@map("role_permission")
}

// 角色数据范围关联表
model RoleDeptScope {
  id           Int       @id @default(autoincrement())
  roleId       Int       @map("role_id")
  deptId       Int       @map("dept_id")
  isDelete     Boolean   @default(false)
  createdAt    DateTime  @default(now()) @map("created_at")

  @@unique([roleId, deptId], name: "uk_role_dept")
  @@map("role_dept_scope")
}

// =============================================================================
// BOM与物料管理
// =============================================================================

// 客户表
model Customer {
  id             Int       @id @default(autoincrement())
  customerCode   String    @unique @map("customer_code") @db.VarChar(50)
  customerName   String    @map("customer_name") @db.VarChar(200)
  customerType   String    @default("enterprise") @map("customer_type") @db.VarChar(20)
  contactPerson  String?   @map("contact_person") @db.VarChar(50)
  contactPhone   String?   @map("contact_phone") @db.VarChar(20)
  contactEmail   String?   @map("contact_email") @db.VarChar(100)
  taxNo          String?   @map("tax_no") @db.VarChar(50)
  bankName       String?   @map("bank_name") @db.VarChar(100)
  bankAccount    String?   @map("bank_account") @db.VarChar(50)
  address        String?   @db.Text
  creditLevel    String?   @map("credit_level") @db.VarChar(10)
  userId         Int?      @map("user_id")
  status         String    @default("active") @db.VarChar(20)
  remark         String?   @db.Text
  isDelete       Boolean   @default(false)
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  createdBy      Int?      @map("created_by")
  modifiedBy     Int?      @map("modified_by")

  @@map("customer")
}

// 客户权限配置表
model CustomerPermission {
  id                 Int       @id @default(autoincrement())
  customerId         Int       @map("customer_id")
  userId             Int?      @map("user_id")
  enableProgressView Boolean   @default(true) @map("enable_progress_view")
  enableDrawingView  Boolean   @default(false) @map("enable_drawing_view")
  enableProcessView  Boolean   @default(true) @map("enable_process_view")
  enableLogisticsView Boolean  @default(true) @map("enable_logistics_view")
  isDelete           Boolean   @default(false)
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  @@map("customer_permission")
}

// 客户反馈表
model CustomerFeedback {
  id            Int       @id @default(autoincrement())
  customerId    Int       @map("customer_id")
  orderId       Int?      @map("order_id")
  userId        Int?      @map("user_id")
  content       String    @db.Text
  feedbackType  String    @default("customer") @map("feedback_type") @db.VarChar(20)
  status        String    @default("pending") @db.VarChar(20)
  replyContent  String?   @map("reply_content") @db.Text
  replierId     Int?      @map("replier_id")
  replyTime     DateTime? @map("reply_time")
  isDelete      Boolean   @default(false)
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  @@map("customer_feedback")
}

// 物料表
model Material {
  id             Int       @id @default(autoincrement())
  uuid           String    @unique @db.VarChar(36)
  materialName   String    @map("material_name") @db.VarChar(200)
  internalCode   String    @unique @map("internal_code") @db.VarChar(50)
  drawingCode    String?   @map("drawing_code") @db.VarChar(50)
  drawingNo      String?   @map("drawing_no") @db.VarChar(50)
  materialType   String    @default("part") @map("material_type") @db.VarChar(20)
  unit           String?   @db.VarChar(20)
  spec           String?   @db.Text
  weight         Decimal?  @map("weight") @db.Decimal(10, 3)
  customerId     Int?      @map("customer_id")
  remark         String?   @db.Text
  isDelete       Boolean   @default(false)
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  createdBy      Int?      @map("created_by")
  modifiedBy     Int?      @map("modified_by")

  @@map("material")
}

// BOM表
model BomItem {
  id               Int       @id @default(autoincrement())
  parentMaterialId Int       @map("parent_material_id")
  childMaterialId  Int       @map("child_material_id")
  quantity         Decimal   @default(1) @db.Decimal(10, 3)
  lossRate         Decimal   @default(0) @map("loss_rate") @db.Decimal(5, 2)
  levelCode        String?   @map("level_code") @db.VarChar(50)
  bomRemark        String?   @map("bom_remark") @db.Text
  isDelete         Boolean   @default(false)
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")
  createdBy        Int?      @map("created_by")
  modifiedBy       Int?      @map("modified_by")

  @@index([parentMaterialId], name: "idx_parent")
  @@index([childMaterialId], name: "idx_child")
  @@map("bom_item")
}

// =============================================================================
// 工艺与工序
// =============================================================================

// 班组表
model Team {
  id           Int       @id @default(autoincrement())
  teamCode     String    @unique @map("team_code") @db.VarChar(50)
  teamName     String    @map("team_name") @db.VarChar(100)
  leaderId     Int?      @map("leader_id")
  teamType     String    @default("processing") @map("team_type") @db.VarChar(20)
  status       String    @default("active") @db.VarChar(20)
  remark       String?   @db.Text
  isDelete     Boolean   @default(false)
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  createdBy    Int?      @map("created_by")
  modifiedBy   Int?      @map("modified_by")

  @@map("team")
}

// 工序表
model Process {
  id               Int       @id @default(autoincrement())
  processCode      String    @unique @map("process_code") @db.VarChar(50)
  processName      String    @map("process_name") @db.VarChar(100)
  processType      String    @default("other") @map("process_type") @db.VarChar(20)
  teamId           Int?      @map("team_id")
  equipmentRequired Boolean  @default(false) @map("equipment_required")
  standardHours    Decimal?  @map("standard_hours") @db.Decimal(10, 2)
  preparationHours Decimal?  @map("preparation_hours") @db.Decimal(10, 2)
  qualityPoints    Int       @default(1) @map("quality_points")
  processOrder     Int       @default(0) @map("process_order")
  status           String    @default("active") @db.VarChar(20)
  remark           String?   @db.Text
  isDelete         Boolean   @default(false)
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")
  createdBy        Int?      @map("created_by")
  modifiedBy       Int?      @map("modified_by")

  @@map("process")
}

// 工艺路线表
model ProcessRoute {
  id             Int       @id @default(autoincrement())
  routeName      String    @map("route_name") @db.VarChar(100)
  materialId     Int       @map("material_id")
  isDefault      Boolean   @default(false) @map("is_default")
  remark         String?   @db.Text
  isDelete       Boolean   @default(false)
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  createdBy      Int?      @map("created_by")
  modifiedBy     Int?      @map("modified_by")

  @@map("process_route")
}

// 工艺路线工序关联表
model RouteProcess {
  id               Int       @id @default(autoincrement())
  routeId          Int       @map("route_id")
  processId        Int       @map("process_id")
  processOrder     Int       @map("process_order")
  standardHours    Decimal?  @map("standard_hours") @db.Decimal(10, 2)
  preparationHours Decimal?  @map("preparation_hours") @db.Decimal(10, 2)
  remarks          String?   @db.Text
  isDelete         Boolean   @default(false)
  createdAt        DateTime  @default(now()) @map("created_at")

  @@unique([routeId, processId], name: "uk_route_process")
  @@map("route_process")
}

// =============================================================================
// 订单管理
// =============================================================================

// 生产订单表
model ProductionOrder {
  id                   Int       @id @default(autoincrement())
  uuid                 String    @unique @db.VarChar(36)
  orderNo              String    @unique @map("order_no") @db.VarChar(50)
  customerOrderNo      String?   @map("customer_order_no") @db.VarChar(50)
  customerId           Int       @map("customer_id")
  materialId           Int       @map("material_id")
  quantity             Int
  deliveredQty         Int       @default(0) @map("delivered_qty")
  unitPrice            Decimal?  @map("unit_price") @db.Decimal(12, 2)
  orderDate            DateTime? @map("order_date") @db.Date
  deliveryDate         DateTime? @map("delivery_date") @db.Date

  nestingPlanDate      DateTime? @map("nesting_plan_date")
  materialPlanDate     DateTime? @map("material_plan_date")
  purchasePlanDate     DateTime? @map("purchase_plan_date")
  productionPlanDate   DateTime? @map("production_plan_date")

  nestingActualDate    DateTime? @map("nesting_actual_date")
  materialActualDate   DateTime? @map("material_actual_date")
  purchaseActualDate   DateTime? @map("purchase_actual_date")
  productionActualDate DateTime? @map("production_actual_date")

  deliveryAddress      String?   @map("delivery_address") @db.Text
  freightBear          String?   @map("freight_bear") @db.VarChar(20)
  projectName          String?   @map("project_name") @db.VarChar(100)
  projectCode          String?   @map("project_code") @db.VarChar(50)
  equipmentNo          String?   @map("equipment_no") @db.VarChar(50)
  equipmentName        String?   @map("equipment_name") @db.VarChar(100)
  surfaceTreatment     String?   @map("surface_treatment") @db.VarChar(100)
  orderStatus          String    @default("pending") @map("order_status") @db.VarChar(20)
  reconciliationStatus String    @default("unreconciled") @map("reconciliation_status") @db.VarChar(20)

  snapshotData         String?   @map("snapshot_data") @db.Text
  progressLog          String?   @map("progress_log") @db.Text
  remark               String?   @db.Text
  isDelete             Boolean   @default(false)
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")
  createdBy            Int?      @map("created_by")
  modifiedBy           Int?      @map("modified_by")

  @@index([customerId], name: "idx_order_customer")
  @@index([orderStatus], name: "idx_order_status")
  @@map("production_order")
}

// 技术任务表
model TechTask {
  id                Int       @id @default(autoincrement())
  orderId           Int       @map("order_id")
  assigneeId        Int?      @map("assignee_id")
  priority          String    @default("normal") @db.VarChar(20)
  dueDate           DateTime? @map("due_date") @db.Date
  bomStatus         String    @default("pending") @map("bom_status") @db.VarChar(20)
  drawingStatus     String    @default("pending") @map("drawing_status") @db.VarChar(20)
  processStatus     String    @default("pending") @map("process_status") @db.VarChar(20)
  attachmentStatus  String    @default("pending") @map("attachment_status") @db.VarChar(20)
  isDelete          Boolean   @default(false)
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")
  createdBy         Int?      @map("created_by")
  modifiedBy        Int?      @map("modified_by")

  @@map("tech_task")
}

// 技术任务BOM表
model TechBomItem {
  id              Int       @id @default(autoincrement())
  taskId          Int       @map("task_id")
  materialId      Int       @map("material_id")
  parentId        Int?      @map("parent_id")
  quantity        Decimal   @default(1) @db.Decimal(10, 3)
