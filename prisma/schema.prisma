  workerId          Int       @map("worker_id")
  pieceWorkAmount   Decimal   @default(0) @map("piece_work_amount") @db.Decimal(12, 2)
  timeWorkAmount    Decimal   @default(0) @map("time_work_amount") @db.Decimal(12, 2)
  overtimeAmount   Decimal   @default(0) @map("overtime_amount") @db.Decimal(12, 2)
  allowance         Decimal   @default(0) @db.Decimal(12, 2)
  deduction         Decimal   @default(0) @db.Decimal(12, 2)
  socialSecurity    Decimal   @default(0) @map("social_security") @db.Decimal(12, 2)
  housingFund       Decimal   @default(0) @map("housing_fund") @db.Decimal(12, 2)
  personalTax       Decimal   @default(0) @map("personal_tax") @db.Decimal(12, 2)
  grossAmount       Decimal   @default(0) @map("gross_amount") @db.Decimal(12, 2)
